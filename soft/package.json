{
  "name": "veic-runtime-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5188",
    "generate:api": "openapi-typescript ../server/openapi.yaml -o src/api/schema.ts",
    "build": "npm run generate:api && tsc --noEmit && vite build",
    "check": "npm run generate:api && tsc --noEmit",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "npm run generate:api && vitest",
    "test:run": "npm run generate:api && vitest run",
    "ci": "npm run check && vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "openapi-fetch": "^0.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
